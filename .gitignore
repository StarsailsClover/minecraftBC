# ================================================
# minecraftBC Git Ignore
# ================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# Testing artifacts
.pytest_cache/
.coverage
htmlcov/
.tox/

# OS files
.DS_Store
Thumbs.db
*.lnk

# Minecraft mod build artifacts
mod/build/
mod/.gradle/
mod/run/
mod/*.log
mod/*.md

# Temporary files
*.tmp
*.temp
*.bak
*.cache

# Local development
*.local
.env
.envrc

# Archives
*.zip
*.tar.gz
*.rar
*.7z

# ================================================
# Non-essential documentation (remove from tracking)
# ================================================

# Development notes (personal, not for release)
ABDC_PLAN.md
AUDIT_*.md
CODE_REVIEW.md
DEV_PLAN.md
DEVELOPMENT_*.md
FASTLINK_INTEGRATION.md
FINAL_RELEASE_*.md
GITHUB_*.md
MARKET_RESEARCH.md
PLANNING.md
PROJECT_STRUCTURE.md
RELEASE_SUMMARY.md
SUMMARY.md
TODO.md
VERSION.md
VERSION_COMPATIBILITY_ANALYSIS.md

# Build scripts (platform specific)
*.sh
*.bat
!mod/gradlew.bat
!mod/gradlew

# IDE configs
*.iml
*.ipr
*.iws
.classpath
.project
.settings/

# ================================================
# KEEP THESE (Essential files)
# ================================================
# .gitignore
# LICENSE
# README.md
# requirements.txt
# src/ (Python source)
# mod/ (Java mod source - build configs and code)
# data/ (Protocol mappings)
# config/ (Default configs)
# examples/ (Config examples)
# docs/API_REFERENCE.md
# docs/USER_MANUAL.md
# tools/ (Utility scripts)
# tests/ (Test files)
